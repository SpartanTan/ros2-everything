<root BTCPP_format="4" >
     <BehaviorTree ID="MainTree">
        <Sequence name="root">
            <Fallback>
                <Inverter>
                    <IsDoorClosed/>
                </Inverter>
                <SubTree ID="DoorClosed"/>
            </Fallback>
            <PassThroughDoor/>
        </Sequence>
     </BehaviorTree>

     <BehaviorTree ID="DoorClsed">
        <Fallback>
            <OpenDoor/>
            <RetryUntilSuccessful num_attempts="5">
                <PickLock/>
            </RetryUntilSuccessful>
            <SmashDoor/>
        </Fallback>
     </BehaviorTree>
 </root>